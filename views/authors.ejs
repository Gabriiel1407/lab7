<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authors</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

<h1>Authors</h1>
<p><a href="/">Back Home</a></p>

<% if (authors.length === 0) { %>
    <p>No authors found.</p>
<% } else { %>

    <% authors.forEach(author => { %>

        <div style="border:1px solid #ccc; padding:10px; margin-bottom:10px;">

            <h2>
                <%= author.firstName %> <%= author.lastName %>
            </h2>

            <p><strong>ID:</strong> <%= author.authorId %></p>

            <p><strong>DOB:</strong>
                <%= author.dob ? author.dob.toISOString().slice(0,10) : "" %>
            </p>

            <p><strong>DOD:</strong>
                <%= author.dod ? author.dod.toISOString().slice(0,10) : "" %>
            </p>

            <p><strong>Sex:</strong> <%= author.sex || "" %></p>
            <p><strong>Profession:</strong> <%= author.profession || "" %></p>
            <p><strong>Country:</strong> <%= author.country || "" %></p>

            <% if (author.portrait) { %>
                <p>
                    <a href="<%= author.portrait %>" target="_blank">View portrait</a>
                </p>
            <% } %>

            <% if (author.biography) { %>
                <p><%= author.biography %></p>
            <% } %>

        </div>

    <% }) %>

<% } %>

</body>
</html>